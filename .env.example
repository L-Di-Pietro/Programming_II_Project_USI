# Copy this file to `.env` and edit values to taste.
# `.env` is gitignored; `.env.example` is committed as the schema-of-record.

# --- Database ----------------------------------------------------------------
# SQLite for local dev (default). Swap to a Postgres URL for production:
#   DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/quantbacktest
DATABASE_URL=sqlite:///./quantbacktest.db

# --- API server --------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# --- Frontend dev proxy ------------------------------------------------------
# The Vite dev server proxies /api/* to this URL.
FRONTEND_API_URL=http://127.0.0.1:8000

# --- Data fetcher tuning -----------------------------------------------------
DATA_FETCH_RETRY_MAX=4
DATA_FETCH_RETRY_BACKOFF_S=2.0   # exponential backoff base
NIGHTLY_REFRESH_HOUR_UTC=23      # APScheduler runs incremental fetch at this UTC hour

# --- LLM (deferred; safe defaults disable all calls) -------------------------
LLM_ENABLED=false
LLM_PROVIDER=null                # null | gemini | (future: anthropic, openai)
LLM_MODEL=gemini-1.5-flash       # ignored when LLM_ENABLED=false
GEMINI_API_KEY=                  # populate to activate Google Gemini
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.2

# --- Backtest engine defaults (overridable per-run via the API) --------------
DEFAULT_INITIAL_CASH=10000.0
DEFAULT_COMMISSION_BPS=5.0       # 5 bps = 0.05% per trade leg
DEFAULT_SLIPPAGE_BPS=2.0         # 2 bps = 0.02% slip
